# =============================================================================
# ktt-platform — Environment Variables
# Hasil mapping dari Laravel .env (data-2/pesbar/app.pesbar.002/.env)
# Aturan: variabel yang dipakai di browser HARUS diawali NEXT_PUBLIC_
# Variabel rahasia (secret/password) TANPA NEXT_PUBLIC_ -> hanya server-side
# =============================================================================

# --- Database (MySQL) — full-stack Next.js + Prisma --------------------------
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Untuk cPanel: pakai user & db yang dibuat di "MySQL Databases".
DATABASE_URL="mysql://root:@localhost:3306/ktt"

# --- Rahasia sesi (JWT login) — WAJIB diisi string acak >= 32 karakter -------
AUTH_SECRET="__ISI_STRING_ACAK_MINIMAL_32_KARAKTER__"

# Base URL untuk client memanggil API sendiri (kosong = relatif, disarankan).
NEXT_PUBLIC_API_URL=

# --- Identitas Situs (publik) ------------------------------------------------
NEXT_PUBLIC_APP_NAME="disdukcapil kab tana tidung - sidako"
NEXT_PUBLIC_APP_URL=https://disdukcapil.tanatidungkab.go.id
NEXT_PUBLIC_APP_KODE=6504

NEXT_PUBLIC_SITE_TENANT=disdukcapil
NEXT_PUBLIC_SITE_TENANT2="dinas dukcapil"
NEXT_PUBLIC_SITE_NAME_FULLNAME="tana tidung"
NEXT_PUBLIC_SITE_NAME_NICKNAME=tanatidung
NEXT_PUBLIC_SITE_NAME_FAMOUS=sidako
NEXT_PUBLIC_SITE_NAME_KET=pelayanan
NEXT_PUBLIC_SITE_NAVBAR_BGCOLOR="rgb(217 119 6 / 70%)"
NEXT_PUBLIC_SITE_NAVBAR_TEXTSHADOW="1px 1px 30px #000"
NEXT_PUBLIC_SITE_VERSION=24.03.30.001
NEXT_PUBLIC_SITE_COPYRIGHT_YEAR=2024
NEXT_PUBLIC_SITE_POWEREDBY="ga tech"

# --- Maps & Relasi (publik) --------------------------------------------------
NEXT_PUBLIC_SITE_MAPS_ALAMAT_EMBED="https://maps.google.com/maps?q=disdukcapil%20tana%20tidung&t=&z=17&ie=UTF8&iwloc=&output=embed"
NEXT_PUBLIC_SITE_MAPS_ALAMAT_KET="Dinas Kependudukan dan Pencatatan Sipil Kabupaten Tana Tidung: Jl. Perkantoran Pemda, Tideng Pale, Kec. Sesayap, Kab. Tana Tidung, Kalimantan Utara"
NEXT_PUBLIC_SITE_MAPS_GIS_JSON=maps_tanatidung
NEXT_PUBLIC_SITE_RELASI_LPSE=https://lpse.tanatidungkab.go.id
NEXT_PUBLIC_SITE_RELASI_DINAS=https://tanatidungkab.go.id

# --- Analytics (publik) ------------------------------------------------------
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-F08BV5LJHS
NEXT_PUBLIC_GOOGLE_TAGMANAGER_ID=GTM-MM4PL9NZ
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION_ID=1e3TDxpiKJ4E1fqCGPeCBNWyiFMuZhFnQk4OG4Z8KJM

# --- reCAPTCHA v3 ------------------------------------------------------------
# Site key boleh publik; secret key HARUS server-side saja.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LemX4QkAAAAALI1aPFAtYfdW5NVWofYzceeYT-o
RECAPTCHA_V3_SECRET_KEY=__ISI_DENGAN_SECRET_KEY__
RECAPTCHA_V3_HOST_NAME=disdukcapil.tanatidungkab.go.id

# --- Database (HANYA jika Next.js akan akses DB langsung; default: lewat backend) ---
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=ktt_db
# DB_USERNAME=ktt_user
# DB_PASSWORD=__ISI_DENGAN_PASSWORD__

# --- Mail (server-side, jika kirim email dari Next.js) -----------------------
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tanatidung.disdukcapil@gmail.com
# MAIL_PASSWORD=__ISI_DENGAN_APP_PASSWORD__
# MAIL_ENCRYPTION=tls

# --- OTP WhatsApp via Fonnte (https://fonnte.com) ----------------------------
# Token DEVICE dari dashboard Fonnte (Devices -> device tersambung -> Token).
# Tanpa token: dev = kode OTP tampil di layar; production = OTP dilewati.
# FONNTE_TOKEN=__ISI_DENGAN_DEVICE_TOKEN__

# --- Halaman Master (buka kunci permohonan final) ----------------------------
# Password akses tertinggi di /dashboard/master. GANTI di production!
# MASTER_PASSWORD=__ISI_DENGAN_PASSWORD_MASTER__
